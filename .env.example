# Copy to .env and fill in your Supabase values.

# Supabase → Settings → Database → Connection string (URI), mode: Session
# lawyerAi project: twoadfuhzukurkixjycn (ap-southeast-2)
SUPABASE_DB_URL=postgresql://postgres.twoadfuhzukurkixjycn:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Cloud Supabase requires SSL (default in db.js). For local/self-hosted PG only:
# PGSSL=disable

PORT=3001
API_KEY=

# Supabase Auth (admin user create / import script)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   # Settings → API → service_role (server only, never expose to frontend)

# Optional discrete connection (used if SUPABASE_DB_URL is empty)
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=postgres

# One-time MySQL → Supabase copy (read-only on MySQL): see scripts/.env.migration.example
