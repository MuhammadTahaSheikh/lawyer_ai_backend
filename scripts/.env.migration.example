# Copy to scripts/.env.migration (gitignored). Used ONLY for one-way copy MySQL → Supabase.
# This process is READ-ONLY on MySQL — it never ALTER/UPDATE/DELETE on the source.

# --- Source: existing AWS MySQL (read-only) ---
MYSQL_HOST=casesdb.cluster-cy05fj2evp1i.us-east-1.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=
MYSQL_DATABASE=casesdb

# --- Target: Supabase project lawyerAi (writes here only) ---
# Project ref: twoadfuhzukurkixjycn | Region: ap-southeast-2
# Supabase → Connect → URI → "Direct connection" (for pgloader bulk copy)
SUPABASE_MIGRATION_URL=postgresql://postgres:[YOUR_SUPABASE_DB_PASSWORD]@db.twoadfuhzukurkixjycn.supabase.co:5432/postgres

# Rows per table: 10 = fast sample (default). 0 = full copy (slow).
MIGRATE_ROW_LIMIT=10

# App runtime (after migration) — Connect → URI → "Session pooler"
# SUPABASE_DB_URL=postgresql://postgres.twoadfuhzukurkixjycn:[YOUR_SUPABASE_DB_PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Supabase Auth admin (import-auth-users script only — never commit service_role)
# SUPABASE_URL=https://twoadfuhzukurkixjycn.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
